{
  "name": "kiosk-portrait",
  "version": "0.0.0",
  "private": true,
  "description": "Kiosk retrato white-label (Next.js + Tailwind + shadcn/ui).",
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
