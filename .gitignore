# Logs
*.log

# Studio audit working dir (keep PDFs in docs/, not here)
.audit/
npm-debug.log*
pnpm-debug.log*
yarn-error.log*

# Claude local state (si aparece)
.claude/*.local.*
.claude/scheduled_tasks.lock
.claude/worktrees/

# Playwright MCP — carpeta residual de la era pre-agent-browser (logs y PNGs
# históricos locales, no se borran pero tampoco entran al repo).
.playwright-mcp/

# graphify — grafo de conocimiento del repo. graph.json pesa ~9.5 MB y el hook
# de Husky lo regenera en cada commit; cada dev lo construye local, no al repo.
graphify-out/

# Orphans históricos de /verificar-visual: PNGs ya validados archivados
# localmente por pnpm clean:screenshots. Pesan MB y no aportan al repo.
.planning/verifications/_orphans-*/

# Test / coverage
coverage/
.nyc_output/

# Temporales
*.tmp
*.bak

# Screenshots transitorios de /verificar-visual (agent-browser) y dev scratchpad.
# Anclados a la raíz para no atrapar assets bajo clients/, clients-signage/, etc.
*-render.png
/billboard-*.png
/b*-*.png
/*.png
.env*.local
.env*.bak*
