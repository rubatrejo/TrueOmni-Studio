# =============================================================================
#  Kiosk Portrait — variables de entorno
# =============================================================================
#
#  Copia este archivo a `.env.local` y personaliza los valores.
#  `.env.local` NO se commitea (está en .gitignore).
#
#  El único valor obligatorio para arrancar es KIOSK_CLIENT.

# --- Cliente activo -----------------------------------------------------------
# Slug de la carpeta en clients/. Debe existir clients/{KIOSK_CLIENT}/.
# Valor por defecto recomendado para desarrollo: default
KIOSK_CLIENT=default

# --- Desarrollo ---------------------------------------------------------------
# Puerto del dev server. Solo cambiar si 3000 está ocupado.
# PORT=3000

# --- Telemetría opcional ------------------------------------------------------
# ID de analytics del cliente, si procede. Se lee también desde config.json.
# ANALYTICS_ID=

# --- Feature overrides (solo debug) -------------------------------------------
# Fuerza un valor distinto al de config.json sin tocar el archivo.
# KIOSK_DEBUG_INACTIVIDAD_SEG=30
