{
  "name": "kiosk-portrait",
  "version": "0.0.0",
  "private": true,
  "description": "Kiosk retrato white-label (Next.js + Tailwind + shadcn/ui).",
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "next build",
    "check": "pnpm typecheck && pnpm lint && pnpm format:check",
    "clean": "rm -rf .next out coverage",
    "dev": "next dev",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,cjs,mjs,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,cjs,mjs,json,md,css}\"",
    "kiosk:dev": "cross-env KIOSK_CLIENT=default next dev",
    "kiosk:new-client": "node scripts/new-client.mjs",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "validate:configs": "node scripts/validate-configs.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "autoprefixer": "^10.5.0",
    "cross-env": "^10.1.0",
    "eslint": "^8",
    "eslint-config-next": "^15",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "postcss": "^8.5.10",
    "postcss-import": "^16.1.1",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^3",
    "typescript": "^5.7.0"
  }
}
